# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string used by Prisma and the pg connection pool.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Example: postgresql://postgres:postgres@localhost:5432/document_management_system?schema=public
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public"

# -----------------------------------------------------------------------------
# NextAuth Authentication Configuration
# -----------------------------------------------------------------------------
# The canonical URL of your application. For local development, this is http://localhost:3000.
NEXTAUTH_URL="http://localhost:3000"

# A secure random string used to encrypt/sign JWTs and session cookies.
# You can generate a strong secret using the following terminal command:
# openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here_at_least_32_characters"

# -----------------------------------------------------------------------------
# AWS S3 Configuration
# -----------------------------------------------------------------------------
# The AWS region where your S3 bucket is hosted.
# Example: us-east-1, ap-northeast-1, etc.
AWS_REGION="ap-northeast-1"

# Access credentials for an IAM User with permissions to read/write/delete objects in the S3 bucket.
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"

# The name of the S3 bucket where uploaded files will be stored.
S3_BUCKET_NAME="your_s3_bucket_name"
